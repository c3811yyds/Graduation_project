# 基础配置
SECRET_KEY=填入你的Flask密钥
JWT_SECRET_KEY=填入你的JWT密钥
DATABASE_URL=mysql+pymysql://user:pwd@IP:3306/db

# Redis 连接地址
# 本地开发可直接连 127.0.0.1:6379；上线到 Docker 后再改成 redis 容器地址
REDIS_URL=redis://127.0.0.1:6379/0

# 本地文件存储目录
# 课程课件、图片、视频等上传文件默认保存在 backend/storage 下
# 如果后续改目录，这里和部署时的挂载路径要保持一致
UPLOAD_DIR=./storage

# 硅基流动 API Key
SILICON_API_KEY=sk-xxxxxxxxxxx这里放硅基流动KEY

# 邮件配置
# MAIL_CONSOLE_FALLBACK 仅建议本地开发时设为 true：
# 没配完整邮件服务时，验证码会只打印到后端控制台，方便调试
# 生产环境建议设为 false，邮件发送失败时直接返回错误提示
MAIL_CONSOLE_FALLBACK=false
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code

# 管理员初始化
# ADMIN_INIT_EMAIL 留空表示不自动创建或提权管理员
# 如果这里填的是已注册邮箱，启动时会直接把该账号角色改成 admin
# 如果想单独新建管理员，请填写一个未注册过的邮箱
# ADMIN_INIT_USERNAME 和 ADMIN_INIT_PASSWORD 只在自动新建管理员账号时生效
ADMIN_INIT_EMAIL=
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=
